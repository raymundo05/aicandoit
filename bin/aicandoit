#!/usr/bin/env bash
# AI Can Do It
# Author: Mike Lopez <e@mikelopez.com>
# Copyright (C) 2026 Mike Lopez <e@mikelopez.com>
# SPDX-License-Identifier: GPL-2.0-only

set -euo pipefail

echo "AI Can Do It"
echo

# --- Usage ---

# Print usage and exit.
usage() {
  cat >&2 <<EOF
Usage: aicandoit --coder <cli[/model]> --reviewer <cli[/model]> [--planner <cli[/model]>] [--mode <stage>] [--worktree] (--branch <name> | --current-branch) <prompt...>

Options:
  -C, --coder <cli[/model]>      Coder CLI: claude, codex, or cursor; optionally append /model (required)
  -R, --reviewer <cli[/model]>   Reviewer CLI: claude, codex, or cursor; optionally append /model; must differ from --coder and --planner by CLI or effective model (required)
  -P, --planner <cli[/model]>    Planner CLI: claude, codex, or cursor; optionally append /model; defaults to --coder
  -M, --mode <stage>             Stage to run: plan, plan-review, code, or code-review; defaults to full workflow
  -W, --worktree                 Run on a branch worktree instead of switching the source checkout
      --verbose                  Show CLI tool output (stderr merged to stdout)
  -B, --branch <name>            Branch to switch to or create
      --current-branch           Use the current git branch
EOF
  exit 1
}

# Split a cli[/model] string into CLI and model parts.
split_cli_model() {
  local value="$1"
  local cli_var="$2"
  local model_var="$3"

  if [[ "$value" == */* ]]; then
    printf -v "$cli_var" '%s' "${value%%/*}"
    printf -v "$model_var" '%s' "${value#*/}"
  else
    printf -v "$cli_var" '%s' "$value"
    printf -v "$model_var" '%s' ""
  fi
}

# Validate cli[/model] formatting when a slash is present.
validate_cli_model() {
  local flag="$1"
  local value="$2"
  local cli="$3"
  local model="$4"

  if [[ "$value" == */* ]]; then
    [[ -z "$cli" ]] && { echo "error: $flag CLI part cannot be empty" >&2; usage; }
    [[ -z "$model" ]] && { echo "error: $flag model part cannot be empty when slash is used" >&2; usage; }
    [[ "$model" == */* ]] && { echo "error: $flag value may only contain one slash (cli/model)" >&2; usage; }
  fi
  return 0
}

# Normalize a model string for CLI comparison.
effective_model() {
  local cli="$1"
  local model="$2"

  if [[ "$cli" == "cursor" ]]; then
    printf '%s' "${model:-$_CURSOR_DEFAULT}"
  else
    printf '%s' "$model"
  fi
}

# Build model args for claude and codex.
build_model_args() {
  local model="$1"
  local -n claude_args="$2"
  local -n codex_args="$3"

  if [[ -n "$model" ]]; then
    claude_args=(--model "$model")
    codex_args=(--model "$model")
  else
    claude_args=()
    codex_args=()
  fi
}

# Build cursor args with the default model fallback.
build_cursor_args() {
  local model="$1"
  local -n cursor_args="$2"

  cursor_args=(--trust --print --model "${model:-$_CURSOR_DEFAULT}")
}

# --- Argument parsing ---

CODER=""
REVIEWER=""
PLANNER=""
BRANCH=""
USE_CURRENT_BRANCH=false
MODE=""
MODE_SET=false
VERBOSE=false
USE_WORKTREE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --coder|-C)
      [[ $# -gt 1 ]] || { echo "error: --coder requires a value" >&2; usage; }
      CODER="$2"; shift 2 ;;
    --reviewer|-R)
      [[ $# -gt 1 ]] || { echo "error: --reviewer requires a value" >&2; usage; }
      REVIEWER="$2"; shift 2 ;;
    --planner|-P)
      [[ $# -gt 1 ]] || { echo "error: --planner requires a value" >&2; usage; }
      PLANNER="$2"; shift 2 ;;
    --mode|-M)
      [[ $# -gt 1 ]] || { echo "error: --mode requires a value" >&2; usage; }
      MODE="$2"; MODE_SET=true; shift 2 ;;
    --worktree|-W) USE_WORKTREE=true; shift ;;
    --verbose) VERBOSE=true; shift ;;
    --branch|-B)
      [[ $# -gt 1 ]] || { echo "error: --branch requires a value" >&2; usage; }
      BRANCH="$2"; shift 2 ;;
    --current-branch) USE_CURRENT_BRANCH=true; shift ;;
    --) shift; break ;;
    -*) echo "error: unknown option: $1" >&2; usage ;;
    *)  break ;;
  esac
done

PROMPT="$*"

if [[ -z "$PLANNER" ]]; then
  PLANNER="$CODER"
fi

# Extract optional model from cli/model format
split_cli_model "$CODER" CODER_CLI CODER_MODEL
split_cli_model "$PLANNER" PLANNER_CLI PLANNER_MODEL
split_cli_model "$REVIEWER" REVIEWER_CLI REVIEWER_MODEL

# Reject malformed cli/model values
validate_cli_model --coder "$CODER" "$CODER_CLI" "$CODER_MODEL"
validate_cli_model --planner "$PLANNER" "$PLANNER_CLI" "$PLANNER_MODEL"
validate_cli_model --reviewer "$REVIEWER" "$REVIEWER_CLI" "$REVIEWER_MODEL"

# --- Validation ---

# Check that a CLI name is supported.
valid_cli() { [[ "$1" == "claude" || "$1" == "codex" || "$1" == "cursor" ]]; }

if ! valid_cli "$CODER_CLI"; then
  echo "error: --coder must be claude, codex, or cursor (got: $CODER_CLI)" >&2
  usage
fi
if ! valid_cli "$PLANNER_CLI"; then
  echo "error: --planner must be claude, codex, or cursor (got: $PLANNER_CLI)" >&2
  usage
fi
if ! valid_cli "$REVIEWER_CLI"; then
  echo "error: --reviewer must be claude, codex, or cursor (got: $REVIEWER_CLI)" >&2
  usage
fi
# Normalize effective models for same-CLI comparison.
# cursor has a built-in default; treat an empty model as that default so
# cursor/gpt-5.3-codex-high and cursor (no model) are treated as identical.
_CURSOR_DEFAULT="gpt-5.3-codex-high"
_CODER_EFF_MODEL="$(effective_model "$CODER_CLI" "$CODER_MODEL")"
_PLANNER_EFF_MODEL="$(effective_model "$PLANNER_CLI" "$PLANNER_MODEL")"
_REVIEWER_EFF_MODEL="$(effective_model "$REVIEWER_CLI" "$REVIEWER_MODEL")"
if [[ "$CODER_CLI" == "$REVIEWER_CLI" && "$_CODER_EFF_MODEL" == "$_REVIEWER_EFF_MODEL" ]]; then
  echo "error: coder and reviewer must differ; use different CLIs or different models" >&2
  exit 1
fi
if [[ "$PLANNER_CLI" == "$REVIEWER_CLI" && "$_PLANNER_EFF_MODEL" == "$_REVIEWER_EFF_MODEL" ]]; then
  echo "error: planner and reviewer must differ; use different CLIs or different models" >&2
  exit 1
fi
PLANNER_MATCHES_CODER=false
if [[ "$PLANNER_CLI" == "$CODER_CLI" && "$_PLANNER_EFF_MODEL" == "$_CODER_EFF_MODEL" ]]; then
  PLANNER_MATCHES_CODER=true
fi
if [[ -n "$BRANCH" && "$USE_CURRENT_BRANCH" == true ]]; then
  echo "error: --branch and --current-branch are mutually exclusive" >&2
  exit 1
fi
if [[ -z "$BRANCH" && "$USE_CURRENT_BRANCH" == false ]]; then
  echo "error: pass --branch <name> or --current-branch" >&2
  usage
fi
if [[ "$USE_WORKTREE" == true && "$USE_CURRENT_BRANCH" == true ]]; then
  echo "error: --worktree does not support --current-branch; pass --branch <name> instead" >&2
  exit 1
fi
if [[ -z "$PROMPT" ]]; then
  echo "error: prompt is required" >&2
  usage
fi
if [[ "$MODE_SET" == true ]]; then
  case "$MODE" in
    plan|plan-review|code|code-review) ;;
    *)
      echo "error: --mode must be plan, plan-review, code, or code-review (got: $MODE)" >&2
      usage
      ;;
  esac
else
  MODE="all"
fi

echo "Coder:    ${CODER_CLI}${CODER_MODEL:+ (model: $CODER_MODEL)}"
echo "Planner:  ${PLANNER_CLI}${PLANNER_MODEL:+ (model: $PLANNER_MODEL)}"
echo "Reviewer: ${REVIEWER_CLI}${REVIEWER_MODEL:+ (model: $REVIEWER_MODEL)}"
echo "Prompt:   $PROMPT"
echo

# --- Dependency checks ---

command -v git >/dev/null || { echo "git not found in PATH" >&2; exit 127; }
command -v gh  >/dev/null || { echo "gh not found in PATH"  >&2; exit 127; }
if [[ "$CODER_CLI" == "claude" || "$PLANNER_CLI" == "claude" || "$REVIEWER_CLI" == "claude" ]]; then
  command -v claude >/dev/null || { echo "claude not found in PATH" >&2; exit 127; }
fi
if [[ "$CODER_CLI" == "codex" || "$PLANNER_CLI" == "codex" || "$REVIEWER_CLI" == "codex" ]]; then
  command -v codex >/dev/null || { echo "codex not found in PATH" >&2; exit 127; }
fi
if [[ "$CODER_CLI" == "cursor" || "$PLANNER_CLI" == "cursor" || "$REVIEWER_CLI" == "cursor" ]]; then
  command -v cursor-agent >/dev/null || { echo "cursor-agent not found in PATH" >&2; exit 127; }
fi

# --- Constants ---

MAX_TRIES="${MAX_TRIES:-20}"
SLEEP_SECS="${SLEEP_SECS:-0.2}"
CODEX_BASE_ARGS="--sandbox workspace-write -a never"
build_cursor_args "$CODER_MODEL" CODER_CURSOR_ARGS
build_cursor_args "$PLANNER_MODEL" PLANNER_CURSOR_ARGS
build_cursor_args "$REVIEWER_MODEL" REVIEWER_CURSOR_ARGS
build_model_args "$CODER_MODEL" CODER_CLAUDE_MODEL CODER_CODEX_MODEL
build_model_args "$PLANNER_MODEL" PLANNER_CLAUDE_MODEL PLANNER_CODEX_MODEL
build_model_args "$REVIEWER_MODEL" REVIEWER_CLAUDE_MODEL REVIEWER_CODEX_MODEL

# Run a CLI command honoring the VERBOSE flag.
run_cli() {
  if [[ "$VERBOSE" == true ]]; then
    "$@" 2>&1
  else
    "$@" >/dev/null 2>&1
  fi
}

# --- Coder functions ---

# Run the initial plan step using the planner role.
run_plan() {
  case "$PLANNER_CLI" in
    claude) run_cli claude "${PLANNER_CLAUDE_MODEL[@]}" -p "/plan-it $PROMPT" ;;
    codex)  run_cli codex $CODEX_BASE_ARGS "${PLANNER_CODEX_MODEL[@]}" exec "\$plan-it $PROMPT" ;;
    cursor) run_cli cursor-agent "${PLANNER_CURSOR_ARGS[@]}" "/plan-it $PROMPT" ;;
  esac
}

# Update the plan using the planner role.
run_plan_update() {
  case "$PLANNER_CLI" in
    claude) run_cli claude "${PLANNER_CLAUDE_MODEL[@]}" -c -p "/plan-update" ;;
    codex)  run_cli codex $CODEX_BASE_ARGS "${PLANNER_CODEX_MODEL[@]}" exec resume --last '$plan-update' ;;
    cursor) run_cli cursor-agent "${PLANNER_CURSOR_ARGS[@]}" --continue '/plan-update' ;;
  esac
}

# Run the code step using the coder role.
run_code() {
  if [[ "$PLANNER_MATCHES_CODER" == true ]]; then
    case "$CODER_CLI" in
      claude) run_cli claude "${CODER_CLAUDE_MODEL[@]}" -c -p "/code-it" ;;
      codex)  run_cli codex $CODEX_BASE_ARGS "${CODER_CODEX_MODEL[@]}" exec resume --last '$code-it' ;;
      cursor) run_cli cursor-agent "${CODER_CURSOR_ARGS[@]}" --continue '/code-it' ;;
    esac
  else
    case "$CODER_CLI" in
      claude) run_cli claude "${CODER_CLAUDE_MODEL[@]}" -p "/code-it" ;;
      codex)  run_cli codex $CODEX_BASE_ARGS "${CODER_CODEX_MODEL[@]}" exec '$code-it' ;;
      cursor) run_cli cursor-agent "${CODER_CURSOR_ARGS[@]}" '/code-it' ;;
    esac
  fi
}

# Run the code fix step using the coder role.
run_code_fix() {
  case "$CODER_CLI" in
    claude) run_cli claude "${CODER_CLAUDE_MODEL[@]}" -c -p "/code-fix" ;;
    codex)  run_cli codex $CODEX_BASE_ARGS "${CODER_CODEX_MODEL[@]}" exec resume --last '$code-fix' ;;
    cursor) run_cli cursor-agent "${CODER_CURSOR_ARGS[@]}" --continue '/code-fix' ;;
  esac
}

# --- Reviewer functions ---

# Run the initial plan review using the reviewer role.
run_plan_review() {
  case "$REVIEWER_CLI" in
    claude) run_cli claude "${REVIEWER_CLAUDE_MODEL[@]}" -p "/plan-review" ;;
    codex)  run_cli codex $CODEX_BASE_ARGS "${REVIEWER_CODEX_MODEL[@]}" exec '$plan-review' ;;
    cursor) run_cli cursor-agent "${REVIEWER_CURSOR_ARGS[@]}" '/plan-review' ;;
  esac
}

# Re-run plan review in the review loop using the reviewer role.
run_plan_review_loop() {
  case "$REVIEWER_CLI" in
    claude) run_cli claude "${REVIEWER_CLAUDE_MODEL[@]}" -c -p "/plan-review" ;;
    codex)  run_cli codex $CODEX_BASE_ARGS "${REVIEWER_CODEX_MODEL[@]}" exec resume --last '$plan-review' ;;
    cursor) run_cli cursor-agent "${REVIEWER_CURSOR_ARGS[@]}" --continue '/plan-review' ;;
  esac
}

# Run the initial code review using the reviewer role.
run_code_review() {
  case "$REVIEWER_CLI" in
    claude) run_cli claude "${REVIEWER_CLAUDE_MODEL[@]}" -c -p "/code-review" ;;
    codex)  run_cli codex $CODEX_BASE_ARGS "${REVIEWER_CODEX_MODEL[@]}" exec resume --last '$code-review' ;;
    cursor) run_cli cursor-agent "${REVIEWER_CURSOR_ARGS[@]}" --continue '/code-review' ;;
  esac
}

# Re-run code review in the review loop using the reviewer role.
run_code_review_loop() {
  case "$REVIEWER_CLI" in
    claude) run_cli claude "${REVIEWER_CLAUDE_MODEL[@]}" -c -p "/code-review" ;;
    codex)  run_cli codex $CODEX_BASE_ARGS "${REVIEWER_CODEX_MODEL[@]}" exec resume --last '$code-review' ;;
    cursor) run_cli cursor-agent "${REVIEWER_CURSOR_ARGS[@]}" --continue '/code-review' ;;
  esac
}

# --- Review loop ---

# Run the review loop until the review file is marked ALL GOOD.
review_loop() {
  local label="$1"
  local file="$2"
  local update_fn="$3"
  local review_fn="$4"
  local updater="$5"
  local tries=0

  echo "$label review loop started..."
  until [[ -f "$file" ]] && grep -q 'ALL GOOD' "$file"; do
    tries=$((tries + 1))
    if (( tries >= MAX_TRIES )); then
      echo "Gave up after $MAX_TRIES tries (no 'ALL GOOD' in $file)" >&2
      exit 2
    fi
    echo "- Loop: $tries"
    echo "- $updater is updating $label..."
    "$update_fn"
    echo "- Reviewer is re-checking $label..."
    "$review_fn"
    sleep "$SLEEP_SECS"
  done
  echo "$label is good!"
}

# Resolve the canonical repository root from the shared git directory.
resolve_repo_root() {
  local common_git_dir=""

  common_git_dir="$(git rev-parse --path-format=absolute --git-common-dir)"
  (
    cd "${common_git_dir}/.."
    pwd -P
  )
}

# Resolve the default branch start ref with remote HEAD and local fallbacks.
resolve_default_start_ref() {
  local default_branch=""
  local start_ref=""

  default_branch="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD | sed 's@^origin/@@')"
  if [[ -n "$default_branch" ]]; then
    printf 'origin/%s\n' "$default_branch"
    return 0
  fi

  if git show-ref --verify --quiet refs/remotes/origin/main; then
    start_ref="origin/main"
  elif git show-ref --verify --quiet refs/heads/main; then
    start_ref="main"
  elif git show-ref --verify --quiet refs/remotes/origin/master; then
    start_ref="origin/master"
  elif git show-ref --verify --quiet refs/heads/master; then
    start_ref="master"
  elif git show-ref --verify --quiet refs/remotes/origin/develop; then
    start_ref="origin/develop"
  elif git show-ref --verify --quiet refs/heads/develop; then
    start_ref="develop"
  else
    start_ref="main"
  fi

  printf '%s\n' "$start_ref"
}

# Build a deterministic worktree path from repo root and branch name.
resolve_worktree_path() {
  local repo_root="$1"
  local branch="$2"
  local branch_path="${branch//\//_}"
  local repo_parent=""
  local repo_name=""

  repo_parent="$(dirname "$repo_root")"
  repo_name="$(basename "$repo_root")"
  printf '%s/%s-worktrees/%s\n' "$repo_parent" "$repo_name" "$branch_path"
}

# Check whether a path is a registered worktree for a branch.
is_registered_worktree_for_branch() {
  local worktree_path="$1"
  local branch="$2"
  local branch_ref="refs/heads/$branch"

  git worktree list --porcelain | awk -v want_path="$worktree_path" -v want_branch="$branch_ref" '
    BEGIN { RS=""; FS="\n"; found=0 }
    {
      path=""
      branch=""
      for (i = 1; i <= NF; i++) {
        if ($i ~ /^worktree /) {
          path=substr($i, 10)
        } else if ($i ~ /^branch /) {
          branch=substr($i, 8)
        }
      }
      if (path == want_path && branch == want_branch) {
        found=1
      }
    }
    END { exit found ? 0 : 1 }
  '
}

# Ensure the target branch worktree exists and is valid.
ensure_worktree_for_branch() {
  local branch="$1"
  local worktree_path="$2"
  local start_ref="$3"
  local source_checkout_path="$4"

  if [[ -e "$worktree_path" ]]; then
    if is_registered_worktree_for_branch "$worktree_path" "$branch"; then
      return 0
    fi
    echo "error: worktree path exists but is not a valid registered worktree for '$branch': $worktree_path" >&2
    exit 1
  fi

  if [[ "$(git -C "$source_checkout_path" rev-parse --abbrev-ref HEAD)" == "$branch" ]]; then
    echo "error: target branch '$branch' is checked out in the source checkout; switch source checkout first or run without --worktree" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$worktree_path")"
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$worktree_path" "$branch"
  else
    git worktree add -b "$branch" "$worktree_path" "$start_ref"
  fi
}

# --- Branch resolution ---

if [[ "$USE_WORKTREE" == true ]]; then
  REPO_ROOT="$(resolve_repo_root)"
  DEFAULT_START_REF="$(resolve_default_start_ref)"
  SOURCE_CHECKOUT_PATH="$(pwd -P)"
  WORKTREE_PATH="$(resolve_worktree_path "$REPO_ROOT" "$BRANCH")"
  echo "Using worktree for branch: $BRANCH"
  echo "Worktree path: $WORKTREE_PATH"
  ensure_worktree_for_branch "$BRANCH" "$WORKTREE_PATH" "$DEFAULT_START_REF" "$SOURCE_CHECKOUT_PATH"
  cd "$WORKTREE_PATH"
else
  if [[ "$USE_CURRENT_BRANCH" == true ]]; then
    BRANCH="$(git rev-parse --abbrev-ref HEAD)"
    if [[ "$BRANCH" == "HEAD" ]]; then
      BRANCH="detached-$(git rev-parse --short HEAD)"
    fi
    echo "Using current branch: $BRANCH"
  else
    if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
      echo "Switching to branch: $BRANCH"
      git checkout "$BRANCH"
    else
      echo "Creating branch: $BRANCH"
      git checkout -b "$BRANCH"
    fi
  fi
fi

BRANCH_PATH="${BRANCH//\//_}"
PLAN_PATH=".ai/branches/${BRANCH_PATH}/plan.md"
PLAN_FILE=".ai/branches/${BRANCH_PATH}/plan-review.md"
CODE_FILE=".ai/branches/${BRANCH_PATH}/code-review.md"

if [[ "$MODE" == "plan-review" ]]; then
  if [[ ! -f "$PLAN_PATH" || ! -f "$PLAN_FILE" ]]; then
    echo "error: --mode plan-review requires an existing plan and plan review; run --mode plan first" >&2
    exit 1
  fi
fi
if [[ "$MODE" == "code" ]]; then
  if [[ ! -f "$PLAN_PATH" ]]; then
    echo "error: --mode code requires an approved plan for this branch; run --mode plan first" >&2
    exit 1
  fi
fi
if [[ "$MODE" == "code-review" ]]; then
  if [[ ! -f "$CODE_FILE" ]]; then
    echo "error: --mode code-review requires an existing code review; run --mode code first" >&2
    exit 1
  fi
fi

# --- Main workflow ---

case "$MODE" in
  plan)
    echo
    echo "Planner is planning..."
    run_plan

    echo "Reviewer is reviewing the plan..."
    run_plan_review
    echo "AI Can Do It finished the workflow."
    exit 0
    ;;
  plan-review)
    review_loop "Plan" "$PLAN_FILE" run_plan_update run_plan_review_loop "Planner"
    echo "AI Can Do It finished the workflow."
    exit 0
    ;;
  code)
    echo
    echo "Coder is implementing..."
    run_code

    echo "Reviewer is reviewing the code..."
    run_code_review
    echo "AI Can Do It finished the workflow."
    exit 0
    ;;
  code-review)
    review_loop "Code" "$CODE_FILE" run_code_fix run_code_review_loop "Coder"
    echo "AI Can Do It finished the workflow."
    exit 0
    ;;
esac

echo
echo "Planner is planning..."
run_plan

echo "Reviewer is reviewing the plan..."
run_plan_review

review_loop "Plan" "$PLAN_FILE" run_plan_update run_plan_review_loop "Planner"

echo
echo "Coder is implementing..."
run_code

echo "Reviewer is reviewing the code..."
run_code_review

review_loop "Code" "$CODE_FILE" run_code_fix run_code_review_loop "Coder"

echo "AI Can Do It finished the workflow."
